  "instructions": {
    "endpoint": "POST /api/models",
    "content_type": "multipart/form-data",
    "parametres": {
      "data": {
        "type": "text/json",
        "description": "Objet ModelRequest au format JSON",
        "obligatoire": true
      },
      "files": {
        "type": "multipart/form-data",
        "description": "List de fichiers images (.jpg, .png, .gif, .webp)",
        "obligatoire": true
      }
    },
    "champs_obligatoires": [
      "nom",
      "description",
      "tissuId",
      "categorieId",
      "couturierId",
      "prix",
      "couleurs",
      "couleurs[].couleurId",
      "couleurs[].ordre",
      "couleurs[].photos",
      "couleurs[].photos[].photoUrl",
      "couleurs[].photos[].principal",
      "couleurs[].photos[].photoOrder"
    ],
    "validations": {
      "nom": "Non vide, max 100 caractères",
      "description": "Non vide, max 100 caractères",
      "tissuId": "ID existant",
      "categorieId": "ID existant",
      "couturierId": "ID existant",
      "prix": "Nombre positif",
      "active": "Boolean (true/false)",
      "couleurId": "ID existant",
      "ordre": "PREMIER, DEUXIEME, TROISIEME, QUATRIEME...",
      "photoUrl": "Nom du fichier téléchargé",
      "principal": "Boolean - au moins une photo doit être true",
      "photoOrder": "Nombre 1-4"
    }
  },
  "comment_utiliser_dans_postman": {
    "etape_1": "Créer une nouvelle requête POST",
    "etape_2": "URL: http://localhost:8080/api/models",
    "etape_3": "Headers: Authorization: Bearer {jwt_token}",
    "etape_4": "Body → form-data",
    "etape_5": "Ajouter un champ 'data' (type: text) avec un des exemples JSON ci-dessus",
    "etape_6": "Ajouter un champ 'files' (type: file) et sélectionner les images",
    "etape_7": "Cliquer Send"
  },
  "ids_valides_exemples": {
    "tissuId": [1, 2, 3],
    "categorieId": [1, 2, 3],
    "couturierId": [4],
    "couleurId": [1, 2, 3, 4, 5, 6]
  },
  "formats_images_acceptes": [
    ".jpg",
    ".jpeg",
    ".png",
    ".gif",
    ".webp"
  ],
  "reponse_attendue": {
    "code": 201,
    "body": {
      "id": "Long",
      "nom": "String",
      "description": "String",
      "prix": "Double",
      "active": "Boolean",
      "visibility": "Boolean",
      "modelColors": [
        {
          "id": "Long",
          "ordre": "Enum",
          "couleur": {
            "id": "Long",
            "nom": "String",
            "codeHex": "String"
          },
          "photos": [
            {
              "id": "Long",
              "photoUrl": "String (URL S3)",
              "principal": "Boolean",
              "photoOrder": "Integer"
            }
          ]
        }
      ]
    }
  },
  "erreurs_courantes": [
    {
      "erreur": "400 Bad Request",
      "cause": "Données JSON invalides dans le champ 'data'",
      "solution": "Vérifier la syntaxe JSON et les types de données"
    },
    {
      "erreur": "401 Unauthorized",
      "cause": "JWT token manquant ou invalide",
      "solution": "Ajouter le header Authorization avec un token valide"
    },
    {
      "erreur": "404 Not Found",
      "cause": "ID inexistant (tissuId, categorieId, couturierId, couleurId)",
      "solution": "Utiliser des IDs valides qui existent en base de données"
    },
    {
      "erreur": "400 Validation Error - Au moins une couleur est obligatoire",
      "cause": "Tableau 'couleurs' vide ou non défini",
      "solution": "Ajouter au moins une couleur avec ses photos"
    },
    {
      "erreur": "400 Validation Error - Les photos sont obligatoires",
      "cause": "Tableau 'photos' vide ou non défini",
      "solution": "Ajouter au moins une photo par couleur"
    },
    {
      "erreur": "500 Internal Server Error",
      "cause": "Erreur lors de l'upload des fichiers S3",
      "solution": "Vérifier la configuration S3 et les permissions"
    }
  ]
}

