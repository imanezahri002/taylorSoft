{
	"info": {
		"_postman_id": "stock-test-collection-2026",
		"name": "TaylorSoft - Stock Automatique Test",
		"description": "Test de la mise à jour automatique du stock quand une commande est livrée",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Préparation - Créer TissuColor",
			"item": [
				{
					"name": "Create TissuColor - Soie Rouge (25 DH)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tissuId\": 1,\n    \"couleurId\": 1,\n    \"photo\": \"soie_rouge.jpg\",\n    \"prixUnitaire\": 25.00,\n    \"active\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tissu-color",
							"host": ["{{base_url}}"],
							"path": ["api", "tissu-color"]
						},
						"description": "Créer un TissuColor Soie Rouge à 25 DH/mètre"
					},
					"response": []
				},
				{
					"name": "Create TissuColor - Coton Bleu (18.5 DH)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tissuId\": 2,\n    \"couleurId\": 2,\n    \"photo\": \"coton_bleu.jpg\",\n    \"prixUnitaire\": 18.50,\n    \"active\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tissu-color",
							"host": ["{{base_url}}"],
							"path": ["api", "tissu-color"]
						},
						"description": "Créer un TissuColor Coton Bleu à 18.5 DH/mètre"
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Test Workflow Complet - Stock Automatique",
			"item": [
				{
					"name": "Step 1 - Vérifier stock AVANT (vide)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/stocks/coutourier/1",
							"host": ["{{base_url}}"],
							"path": ["api", "stocks", "coutourier", "1"]
						},
						"description": "Doit retourner [] car aucune commande livrée"
					},
					"response": []
				},
				{
					"name": "Step 2 - Créer commande (50m Soie + 30m Coton)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"couturierId\": 1,\n    \"fournisseurId\": 1,\n    \"status\": \"EN_ATTENTE\",\n    \"items\": [\n        {\n            \"tissuColorId\": 1,\n            \"nombreMetres\": 50\n        },\n        {\n            \"tissuColorId\": 2,\n            \"nombreMetres\": 30\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/coutourier-orders",
							"host": ["{{base_url}}"],
							"path": ["api", "coutourier-orders"]
						},
						"description": "Créer commande: 50m Soie Rouge + 30m Coton Bleu\nPrix: (50×25) + (30×18.5) = 1805 DH"
					},
					"response": []
				},
				{
					"name": "Step 3 - Confirmer commande",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/coutourier-orders/1/status?status=CONFIRMEE",
							"host": ["{{base_url}}"],
							"path": ["api", "coutourier-orders", "1", "status"],
							"query": [{ "key": "status", "value": "CONFIRMEE" }]
						},
						"description": "Fournisseur confirme la commande"
					},
					"response": []
				},
				{
					"name": "Step 4 - En préparation",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/coutourier-orders/1/status?status=EN_PREPARATION",
							"host": ["{{base_url}}"],
							"path": ["api", "coutourier-orders", "1", "status"],
							"query": [{ "key": "status", "value": "EN_PREPARATION" }]
						},
						"description": "Commande en cours de préparation"
					},
					"response": []
				},
				{
					"name": "Step 5 - Expédiée",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/coutourier-orders/1/status?status=EXPEDIE",
							"host": ["{{base_url}}"],
							"path": ["api", "coutourier-orders", "1", "status"],
							"query": [{ "key": "status", "value": "EXPEDIE" }]
						},
						"description": "Fournisseur expédie la commande"
					},
					"response": []
				},
				{
					"name": "Step 6 - 🎯 LIVRÉE (Stock AUTO ✨)",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/coutourier-orders/1/status?status=LIVREE",
							"host": ["{{base_url}}"],
							"path": ["api", "coutourier-orders", "1", "status"],
							"query": [{ "key": "status", "value": "LIVREE" }]
						},
						"description": "✨ MAGIE: Le stock est automatiquement mis à jour!\n- Soie Rouge: +50m\n- Coton Bleu: +30m\n- 2 mouvements créés (type: IN)"
					},
					"response": []
				},
				{
					"name": "Step 7 - Vérifier stock APRÈS livraison ✅",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/stocks/coutourier/1",
							"host": ["{{base_url}}"],
							"path": ["api", "stocks", "coutourier", "1"]
						},
						"description": "Doit retourner 2 stocks:\n- Soie Rouge: 50m\n- Coton Bleu: 30m\nAvec mouvements de type IN"
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Test Stock Cumulé",
			"item": [
				{
					"name": "Créer 2ème commande (25m Soie)",
					"request": {
